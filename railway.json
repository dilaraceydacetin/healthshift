{
  "$schema": "https://schema.railway.app/railway-schema.json",
  "services": {
    "energy": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "energy/Dockerfile"
      },
      "deploy": {
        "startCommand": "uvicorn energy.main:app --host 0.0.0.0 --port $PORT"
      }
    }
  }
}
